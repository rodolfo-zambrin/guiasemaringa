    "Loop por Conta": { "main": [[{ "node": "Meta Insights API (horário)", "type": "main", "index": 0 }]] },
    "Meta Insights API (horário)": { "main": [[{ "node": "Transformar Dados Horários", "type": "main", "index": 0 }]] },
    "Transformar Dados Horários": { "main": [[{ "node": "Tem dados?", "type": "main", "index": 0 }]] },
    "Tem dados?": { "main": [[{ "node": "Salvar no Supabase", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "staticData": null,
  "meta": { "templateCredsSetupCompleted": true },
  "pinData": {}
}
