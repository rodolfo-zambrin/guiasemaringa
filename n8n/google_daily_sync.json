      "id": "node-config",
      "name": "Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Config').item.json.SUPABASE_URL }}/rest/v1/ad_accounts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $('Config').item.json.SUPABASE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $('Config').item.json.SUPABASE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "platform",  "value": "eq.google" },
            { "name": "is_active", "value": "eq.true" },
            { "name": "select",    "value": "account_id,account_name,client_id" }
          ]
        },
        "options": {}
      },
      "id": "node-get-accounts",
      "name": "Buscar Contas Google",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Config').item.json.SUPABASE_URL }}/rest/v1/agency_api_tokens",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $('Config').item.json.SUPABASE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $('Config').item.json.SUPABASE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "agency_id", "value": "=eq.{{ $('Config').item.json.AGENCY_ID }}" },
            { "name": "platform",  "value": "eq.google" },
            { "name": "is_active", "value": "eq.true" },
            { "name": "select",    "value": "access_token,token_name" }
          ]
        },
        "options": {}
      },
      "id": "node-get-agency-token",
      "name": "Buscar Token Agência Google",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $('Config').item.json.SUPABASE_URL }}/rest/v1/client_api_tokens",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $('Config').item.json.SUPABASE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $('Config').item.json.SUPABASE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "platform",  "value": "eq.google" },
            { "name": "is_active", "value": "eq.true" },
            { "name": "select",    "value": "client_id,access_token" }
          ]
        },
        "options": {}
      },
      "id": "node-get-client-tokens",
      "name": "Buscar Tokens Clientes Google",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "alwaysOutputData": true,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// N8N separa array JSON em items individuais — .all() retorna N items, cada .json é 1 registro\nconst accounts    = $('Buscar Contas Google').all().map(item => item.json);\nconst agencyItems = $('Buscar Token Agência Google').all();\nconst clientItems = $('Buscar Tokens Clientes Google').all();\n\nconst agencyToken = agencyItems.length > 0 ? agencyItems[0].json?.access_token : null;\n\nconst clientTokenMap = {};\nfor (const item of clientItems) {\n  if (item.json?.client_id) clientTokenMap[item.json.client_id] = item.json.access_token;\n}\n\nconst dateFrom         = $('Config').item.json.DATE_FROM;\nconst dateTo           = $('Config').item.json.DATE_TO;\nconst developerToken   = $('Config').item.json.DEVELOPER_TOKEN;\nconst managerAccountId = $('Config').item.json.MANAGER_ACCOUNT_ID;\n\nreturn accounts.map(acc => ({\n  json: {\n    account_id:         acc.account_id.replace(/-/g, ''),  // remove hyphens: '842-650-4432' → '8426504432'\n    account_id_display: acc.account_id,\n    account_name:       acc.account_name,\n    client_id:          acc.client_id,\n    access_token:       clientTokenMap[acc.client_id] ?? agencyToken,\n    developer_token:    developerToken,\n    manager_account_id: managerAccountId,\n    date_from:          dateFrom,\n    date_to:            dateTo,\n    supabase_url:       $('Config').item.json.SUPABASE_URL,\n    supabase_key:       $('Config').item.json.SUPABASE_KEY\n  }\n}));\n"
      },
      "id": "node-build-list",
      "name": "Montar Lista Contas Google",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "node-loop",
      "name": "Loop por Conta Google",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://googleads.googleapis.com/v17/customers/{{ $json.account_id }}/googleAds:search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization",       "value": "=Bearer {{ $json.access_token }}" },
            { "name": "developer-token",     "value": "={{ $json.developer_token }}" },
            { "name": "login-customer-id",   "value": "={{ $json.manager_account_id }}" },
            { "name": "Content-Type",        "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ query: `SELECT customer.id, customer.currency_code, segments.date, metrics.cost_micros, metrics.impressions, metrics.clicks, metrics.conversions, metrics.conversions_value, metrics.ctr, metrics.average_cpc, metrics.average_cpm FROM customer WHERE segments.date BETWEEN '${$json.date_from}' AND '${$json.date_to}'` }) }}",
        "options": {}
      },
      "id": "node-google-api",
      "name": "Google Ads API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 220]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = [];\nconst loopItem = $('Loop por Conta Google').item.json;\n\nfor (const item of $input.all()) {\n  const rows = item.json?.results ?? [];\n\n  for (const row of rows) {\n    const costMicros = parseInt(row.metrics?.costMicros ?? 0);\n    const spend = costMicros / 1_000_000;\n    const avgCpcMicros = parseInt(row.metrics?.averageCpc ?? 0);\n    const avgCpc = avgCpcMicros / 1_000_000;\n    const avgCpmMicros = parseInt(row.metrics?.averageCpm ?? 0);\n    const avgCpm = avgCpmMicros / 1_000_000;\n\n    items.push({\n      json: {\n        account_id:       loopItem.account_id_display,  // store with hyphens: '842-650-4432'\n        date:             row.segments?.date,\n        spend:            spend,\n        impressions:      parseInt(row.metrics?.impressions ?? 0),\n        clicks:           parseInt(row.metrics?.clicks ?? 0),\n        conversions:      parseFloat(row.metrics?.conversions ?? 0),\n        conversion_value: parseFloat(row.metrics?.conversionsValue ?? 0),\n        ctr:              parseFloat(row.metrics?.ctr ?? 0),\n        avg_cpc:          avgCpc,\n        avg_cpm:          avgCpm,\n        synced_at:        new Date().toISOString(),\n        _supabase_url:    loopItem.supabase_url,\n        _supabase_key:    loopItem.supabase_key\n      }\n    });\n  }\n}\nreturn items.length > 0 ? items : [{ json: { _skip: true } }];\n"
      },
      "id": "node-parse",
      "name": "Transformar Dados Google",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 220]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true },
          "conditions": [
            {
              "leftValue": "={{ $json._skip }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "notEquals" }
            }
          ]
        }
      },
      "id": "node-filter",
      "name": "Tem dados Google?",
      "type": "n8n-nodes-base.filter",
      "typeVersion": 2,
      "position": [2220, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json._supabase_url }}/rest/v1/google_account_daily",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $json._supabase_key }}" },
            { "name": "Authorization", "value": "=Bearer {{ $json._supabase_key }}" },
            { "name": "Content-Type",  "value": "application/json" },
            { "name": "Prefer",        "value": "resolution=merge-duplicates" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ account_id: $json.account_id, date: $json.date, spend: $json.spend, impressions: $json.impressions, clicks: $json.clicks, conversions: $json.conversions, conversion_value: $json.conversion_value, ctr: $json.ctr, avg_cpc: $json.avg_cpc, synced_at: $json.synced_at }) }}",
        "options": {}
      },
      "id": "node-upsert",
      "name": "Salvar Google no Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2440, 220]
    }
  ],
  "connections": {
