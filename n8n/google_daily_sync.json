            { "id": "c1", "name": "SUPABASE_URL",        "value": "https://lsccpbfuatpwycrtksrb.supabase.co",  "type": "string" },
            { "id": "c2", "name": "SUPABASE_KEY",        "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxzY2NwYmZ1YXRwd3ljcnRrc3JiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDg4MzY3MywiZXhwIjoyMDkwNDU5NjczfQ.NwYOCZ9_udnORBFga0ADTSZRxYqbTvaDlnyEfr5xod8",        "type": "string" },
            { "id": "c3", "name": "AGENCY_ID",           "value": "00000000-0000-0000-0000-000000000001", "type": "string" },
