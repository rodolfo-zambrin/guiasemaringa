    "Tem dados Google?": {
      "main": [
        [{ "node": "Salvar Google no Supabase", "type": "main", "index": 0 }],
        [{ "node": "Loop por Conta Google",     "type": "main", "index": 0 }]
      ]
    },
    "Salvar Google no Supabase":   { "main": [[{ "node": "Loop por Conta Google",         "type": "main", "index": 0 }]] }
  },
  "active": false,
  "settings": { "executionOrder": "v1" },
