# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — NEVER expose to browser, used only by n8n/server-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://agperform.com.br
NEXT_PUBLIC_APP_NAME=AG Perform

# ─────────────────────────────────────────────
# Meta Ads API (used by n8n workflows)
# Get from: developers.facebook.com → your app → tokens
# ─────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Long-lived System User token (never expires) — recommended for production
META_ACCESS_TOKEN=your-meta-long-lived-access-token

# ─────────────────────────────────────────────
# Google Ads API (used by n8n workflows)
# Get from: console.cloud.google.com + ads.google.com/home/tools/manager-accounts
# ─────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# Manager Account (MCC) ID — without hyphens
GOOGLE_ADS_MCC_ID=1234567890

# ─────────────────────────────────────────────
# Windsor.ai (alternative data source)
# ─────────────────────────────────────────────
WINDSOR_API_KEY=your-windsor-api-key

# ─────────────────────────────────────────────
# n8n (if self-hosted)
# ─────────────────────────────────────────────
N8N_WEBHOOK_SECRET=your-webhook-secret
